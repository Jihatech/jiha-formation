# ── Plateforme jiha.tech — variables d'environnement ─────────────────────────
# Copier en .env.local et renseigner. Ne JAMAIS committer .env.local.

# URL publique du site (dev: http://localhost:3000 ; prod: l'URL Vercel).
# Sert au canonical, aux hreflang et aux redirections OAuth.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Supabase — clé service_role (SECRÈTE, serveur uniquement : suppression RGPD).
# Ne jamais préfixer NEXT_PUBLIC_ — ne doit jamais atteindre le navigateur.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Source du contenu (optionnel — défaut : repo JIHA-Learn main).
# JIHA_LEARN_RAW_BASE=https://raw.githubusercontent.com/Jihatech/JIHA-Learn/main
